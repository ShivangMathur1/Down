[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx, unshaded;

uniform vec2 Speed;
uniform sampler2D Base_Texture : source_color, repeat_enable;
uniform sampler2D Subtraction_texture : source_color;
uniform sampler2D Color_1D_Gradient : source_color, repeat_disable;
uniform float Aplha_Scissor_Threshold : hint_range(0.0, 1.0) = 1.0;



void fragment() {
// Vector2Parameter:5
	vec2 n_out5p0 = Speed;


// Input:6
	float n_out6p0 = TIME;


// VectorOp:7
	vec2 n_out7p0 = n_out5p0 * vec2(n_out6p0);


// UVFunc:4
	vec2 n_in4p1 = vec2(1.00000, 1.00000);
	vec2 n_out4p0 = n_out7p0 * n_in4p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Base_Texture, n_out4p0);
	float n_out3p1 = n_out3p0.r;


	vec4 n_out8p0;
// Texture2D:8
	n_out8p0 = texture(Subtraction_texture, UV);
	float n_out8p1 = n_out8p0.r;


// FloatOp:10
	float n_out10p0 = n_out3p1 - n_out8p1;


// Clamp:11
	float n_in11p1 = 0.00000;
	float n_in11p2 = 1.00000;
	float n_out11p0 = clamp(n_out10p0, n_in11p1, n_in11p2);


	vec4 n_out13p0;
// Texture2D:13
	n_out13p0 = texture(Color_1D_Gradient, vec2(n_out11p0));
	float n_out13p4 = n_out13p0.a;


// FloatParameter:14
	float n_out14p0 = Aplha_Scissor_Threshold;


// Output:0
	ALBEDO = vec3(n_out13p0.xyz);
	ALPHA = n_out13p4;
	ALPHA_SCISSOR_THRESHOLD = n_out14p0;


}
